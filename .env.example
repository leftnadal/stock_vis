# Stock-Vis Environment Variables Example
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# ============================================================
# API Keys
# ============================================================

# Alpha Vantage API Key (https://www.alphavantage.co/support/#api-key)
# 무료 티어: 5 calls/min, 500 calls/day
ALPHA_VANTAGE_API_KEY="your_alpha_vantage_api_key_here"

# Financial Modeling Prep API Key (https://financialmodelingprep.com/developer)
# 무료 티어: 250 calls/day
FMP_API_KEY="your_fmp_api_key_here"

# Finnhub API Key (https://finnhub.io/)
# 무료 티어: 60 calls/min
# 용도: 실시간 뉴스, 감성 분석
FINNHUB_API_KEY="your_finnhub_api_key_here"

# Marketaux API Key (https://www.marketaux.com/)
# 무료 티어: 100 calls/day
# 용도: 종합 뉴스, 엔티티 추출
MARKETAUX_API_KEY="your_marketaux_api_key_here"

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# Stock Data Provider Configuration
# ============================================================
# Provider 선택: "alpha_vantage" 또는 "fmp"
# 각 엔드포인트별로 다른 provider를 사용할 수 있습니다.

# 기본값: 모든 엔드포인트에서 Alpha Vantage 사용
# Phase 3에서 아래 값들을 fmp로 변경하여 FMP 전환 가능

STOCK_PROVIDER_QUOTE=alpha_vantage
STOCK_PROVIDER_PROFILE=alpha_vantage
STOCK_PROVIDER_DAILY_PRICES=alpha_vantage
STOCK_PROVIDER_WEEKLY_PRICES=alpha_vantage
STOCK_PROVIDER_BALANCE_SHEET=alpha_vantage
STOCK_PROVIDER_INCOME_STATEMENT=alpha_vantage
STOCK_PROVIDER_CASH_FLOW=alpha_vantage
STOCK_PROVIDER_SEARCH=alpha_vantage
STOCK_PROVIDER_SECTOR=alpha_vantage

# Fallback Provider 활성화 (주 provider 실패 시 대체 provider 사용)
PROVIDER_FALLBACK_ENABLED=True

# ============================================================
# Neo4j (Knowledge Graph Database)
# ============================================================

# 로컬 개발 환경 (docker-compose neo4j 서비스)
# NEO4J_PASSWORD: 운영 환경에서 미설정 시 startup 차단됨. 강력한 패스워드 사용
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Neo4j Aura (클라우드 환경) - Optional
# NEO4J_USE_AURA=True
# NEO4J_URI=neo4j+s://your_instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_neo4j_password
# AURA_INSTANCEID=your_instance_id
# AURA_INSTANCENAME=your_instance_name

# ============================================================
# Redis (Celery + Cache)
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================
# News API Settings
# ============================================================

# News API 우선순위 설정 (기본값: finnhub)
NEWS_PRIMARY_PROVIDER=finnhub
NEWS_FALLBACK_PROVIDER=marketaux

# ============================================================
# Django Settings (보안 필수)
# ============================================================
# SECRET_KEY: 운영 환경(DJANGO_DEBUG=False)에서 미설정 시 startup 차단됨
# 생성: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# JWT_SIGNING_KEY: 별도 회전을 위해 SECRET_KEY와 분리. 미설정 시 SECRET_KEY로 fallback
# 생성: 위 SECRET_KEY와 동일한 명령어로 별도 생성 권장
JWT_SIGNING_KEY=

# DJANGO_DEBUG: True/False (대소문자 무관). 기본 False (운영 안전 기본값)
# 개발 시: DJANGO_DEBUG=True
DJANGO_DEBUG=True

# DJANGO_ALLOWED_HOSTS: 쉼표 구분. DEBUG=True 시 자동 ['*']
# 운영 예: DJANGO_ALLOWED_HOSTS=stockvis.com,api.stockvis.com
DJANGO_ALLOWED_HOSTS=

# DJANGO_CORS_ALLOW_ALL: 모든 origin 허용 여부 (기본 False).
# 명시 origin은 settings.py의 CORS_ALLOWED_ORIGINS에서 관리
DJANGO_CORS_ALLOW_ALL=False
