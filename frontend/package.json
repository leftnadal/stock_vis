{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -f .next/dev/lock",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:coach-schema": "cd .. && poetry run python manage.py spectacular --file frontend/lib/coach/schema.yml",
